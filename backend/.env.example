# 应用基础信息
APP_NAME=DevFlow Platform
APP_VERSION=0.1.0

# 运行环境：local、test、production
ENVIRONMENT=local

# 本地开发可开启，生产环境必须关闭
DEBUG=true

# API v1 统一访问前缀
API_V1_PREFIX=/api/v1

# MySQL 容器初始化配置
MYSQL_ROOT_PASSWORD=devflow_root_password

# FastAPI 数据库连接配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=devflow
MYSQL_PASSWORD=devflow_password
MYSQL_DATABASE=devflow