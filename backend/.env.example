# 应用基础信息
APP_NAME=DevFlow Platform
APP_VERSION=0.1.0

# 运行环境：local、test、production
ENVIRONMENT=local

# 本地开发可开启，生产环境必须关闭
DEBUG=true

# API v1 统一访问前缀
API_V1_PREFIX=/api/v1

# JWT 配置；部署时必须替换为高强度随机值
JWT_SECRET_KEY=replace-with-a-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# MySQL 容器初始化配置
MYSQL_ROOT_PASSWORD=devflow_root_password

# FastAPI 数据库连接配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=devflow
MYSQL_PASSWORD=devflow_password
MYSQL_DATABASE=devflow

# Redis/Celery 为增强能力；不可用时不影响核心 API 启动
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
